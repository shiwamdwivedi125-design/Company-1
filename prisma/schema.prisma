generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Analysis {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  transcript      String
  result          String   // We'll store the JSON string here
  fellowName      String?
  score           Int?
  label           String?
}
